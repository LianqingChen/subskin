# SubSkin Backend 环境变量示例
# 复制为 .env 并填入实际配置

# 数据库连接 URL
# 开发：sqlite:///./data/subskin.db
# 生产 PostgreSQL：postgresql://user:password@localhost/subskin
DATABASE_URL=sqlite:///./data/subskin.db

# JWT 密钥（生产环境必须修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# Access Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 初始管理员账号
ADMIN_USER=admin
ADMIN_PASS=change-this-to-secure-password

# 短信配置
SMS_PROVIDER=log  # log开发模式 / aliyun阿里云 / tencent腾讯云
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=SubSkin
SMS_TEMPLATE_CODE=

# OpenAI / LLM 配置（RAG 问答需要）
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1  # 可改成第三方代理
LLM_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small

# 微信开放平台配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_REDIRECT_URI=https://your-domain.com/api/oauth/wechat/callback

# 支付宝开放平台配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-rsa-private-key
ALIPAY_PUBLIC_KEY=your-rsa-public-key
ALIPAY_REDIRECT_URI=https://your-domain.com/api/oauth/alipay/callback

# 腾讯云短信配置
TENCENT_SMS_APP_ID=your-tencent-sms-app-id
TENCENT_SMS_TEMPLATE_ID=your-tencent-sms-template-id
