# API Keys for SubSkin Project
# Copy this file to .env and fill in your actual API keys

# PubMed/NCBI API
NCBI_API_KEY=your_ncbi_api_key_here

# OpenAI API for translation and summarization
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Semantic Scholar API
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# Optional: Anthropic API (alternative to OpenAI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration (for future PostgreSQL support)
DATABASE_URL=postgresql://user:password@localhost:5432/subskin

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# Website Configuration
SITE_URL=https://subskin.example.com
SITE_NAME=SubSkin
SITE_DESCRIPTION=白癜风百科全书与社区

# Email Configuration (for weekly digests)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# GitHub OAuth (for user authentication)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Security
SECRET_KEY=your_secret_key_for_session_encryption
JWT_SECRET_KEY=your_jwt_secret_key

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/subskin.log

# ============================================
# Production Environment Configuration (阿里云ECS)
# ============================================

# Scheduler Configuration (每日自动执行)
SCHEDULER_ENABLED=true
DAILY_UPDATE_TIME=02:00  # 每天凌晨2点执行（UTC时间）
UPDATE_RETRY_ATTEMPTS=3
UPDATE_RETRY_DELAY=300  # 重试延迟秒数

# Incremental Update Tracking
TRACK_INCREMENTAL_UPDATES=true
UPDATE_HISTORY_DAYS=30  # 保留更新历史天数

# Notification Configuration (QQ机器人 via openclaw)
QQ_BOT_ENABLED=true
QQ_BOT_API_URL=http://localhost:8080  # openclaw API地址
QQ_BOT_ACCESS_TOKEN=your_qq_bot_access_token
QQ_NOTIFICATION_GROUP=your_qq_group_id  # QQ群号
QQ_NOTIFICATION_ADMIN=your_qq_admin_id  # 管理员QQ号

# Storage Configuration (阿里云OSS - 可选)
ALIYUN_OSS_ENABLED=false
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=your-bucket-name
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *  # 每天凌晨3点（cron格式）
BACKUP_RETENTION_DAYS=7

# Monitoring & Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PORT=8080
METRICS_ENABLED=true
METRICS_PORT=9090

# Performance Configuration
WORKER_PROCESSES=4  # 工作进程数（根据ECS配置调整）
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT_SECONDS=3600  # 任务超时时间（1小时）

# Data Retention Policy
RAW_DATA_RETENTION_DAYS=90
PROCESSED_DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=30

# Email Notifications (for errors and alerts)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_RECIPIENT=admin@example.com
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=alert@example.com
ALERT_EMAIL_SMTP_PASSWORD=your_alert_email_password